# ===========================================
# SEO Tool - Environment Variables
# ===========================================

# App Settings
APP_NAME=SEO Tool
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/seo_tool.db

# Google Search API (for rank tracking)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# Google PageSpeed Insights API
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# Moz API (for domain authority)
MOZ_ACCESS_ID=your_moz_access_id_here
MOZ_SECRET_KEY=your_moz_secret_key_here

# Ahrefs API (optional)
AHREFS_API_KEY=your_ahrefs_api_key_here

# ===========================================
# AI Provider API Keys
# ===========================================

# OpenAI (GPT-4o, GPT-4o-mini, GPT-4-turbo)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=  # Leave empty for default, or set for Azure/custom endpoint

# Anthropic (Claude Sonnet 4, Claude 3.5 Haiku)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini (Gemini 2.0 Flash, Gemini 1.5 Pro)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (Llama 3.3, Mixtral - ultra-fast inference)
GROQ_API_KEY=your_groq_api_key_here

# Mistral AI (Mistral Large)
MISTRAL_API_KEY=your_mistral_api_key_here

# Cohere (Command R+)
COHERE_API_KEY=your_cohere_api_key_here

# AI Defaults
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o-mini
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# Crawling Settings
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30
USER_AGENT=SEOTool/1.0 (+https://github.com/your-repo)
CRAWL_DELAY=1.0

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Report Settings
REPORT_OUTPUT_DIR=./reports
REPORT_FORMAT=html

# Scheduling (cron format for rank tracking)
RANK_CHECK_SCHEDULE=0 6 * * *
